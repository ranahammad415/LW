{
  "name": "agency-intelligence-portal-api",
  "version": "1.0.0",
  "description": "Agency Intelligence Portal — Fastify + Prisma API",
  "type": "module",
  "main": "src/index.js",
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "scripts": {
    "dev": "node --watch src/index.js",
    "start": "node src/index.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "node prisma/seed.js",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --pool=forks --poolOptions.forks.singleFork=true tests/api/",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.88.0",
    "@fastify/cookie": "^10.0.1",
    "@fastify/cors": "^10.1.0",
    "@fastify/multipart": "^9.4.0",
    "@fastify/static": "^9.1.0",
    "@prisma/client": "^6.0.0",
    "axios": "^1.7.0",
    "bcrypt": "^5.1.1",
    "csv-parser": "^3.2.0",
    "fast-xml-parser": "^4.3.0",
    "fastify": "^5.0.0",
    "fastify-type-provider-zod": "^5.0.0",
    "google-auth-library": "^10.6.2",
    "googleapis": "^171.4.0",
    "jsonwebtoken": "^9.0.3",
    "mysql2": "^3.11.0",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.5",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "dotenv": "^16.4.5",
    "prisma": "^6.0.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=18"
  }
}
