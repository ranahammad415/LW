# Database (MySQL) — local install example:
# DATABASE_URL="mysql://root:YOUR_PASSWORD@localhost:3306/localwaves"
# Replace YOUR_PASSWORD with the password you set for the MySQL root user during installation.
DATABASE_URL="mysql://user:password@localhost:3306/localwaves"

# JWT — required; each secret must be at least 32 characters (use long random strings in production)
# Example (replace with your own): JWT_ACCESS_SECRET=abcdefghijklmnopqrstuvwxyz123456
JWT_ACCESS_SECRET=your-access-secret-min-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Server
PORT=3000
NODE_ENV=development

# AI — Anthropic Claude Haiku
# Get your API key at https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key
# AI_MODEL=claude-haiku-4-5-20250514

# Google OAuth (for client Google Sign-In & analytics access)
# Create credentials at https://console.cloud.google.com/apis/credentials
# GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your-google-client-secret
# GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback
# FRONTEND_URL=http://localhost:5173

# Google Search Console — Service Account key file path
# Create a Service Account at https://console.cloud.google.com/iam-admin/serviceaccounts
# Enable Search Console API, download JSON key, and set the path here.
# Add the service account email as a user in each GSC property.
# GOOGLE_SERVICE_ACCOUNT_KEY=/path/to/service-account-key.json
