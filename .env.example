# Database (MySQL) — local install example:
# DATABASE_URL="mysql://root:YOUR_PASSWORD@localhost:3306/localwaves"
# Replace YOUR_PASSWORD with the password you set for the MySQL root user during installation.
DATABASE_URL="mysql://user:password@localhost:3306/localwaves"

# JWT — required; each secret must be at least 32 characters (use long random strings in production)
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_ACCESS_SECRET=your-access-secret-min-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Signed-cookie secret — MUST differ from the JWT secrets (min 32 chars)
COOKIE_SECRET=your-cookie-secret-min-32-chars

# Rate limiting (optional — defaults applied in code if unset)
# RATE_LIMIT_LOGIN_MAX=10
# RATE_LIMIT_LOGIN_WINDOW=15 minutes

# Trust proxy (set to true when behind nginx/Cloudflare so request.ip is correct)
# TRUST_PROXY=false

# Server
PORT=3000
NODE_ENV=development

# AI — Anthropic Claude Haiku
# Get your API key at https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key
# AI_MODEL=claude-haiku-4-5-20250514

# ── Nova voice (OpenAI Whisper STT + OpenAI TTS) ──
# Enables the mic + speaker buttons on the Nova client assistant.
# Uses the shared OPENAI_API_KEY below. Leave unset to disable voice features.
# OPENAI_API_KEY=your-openai-key
# OPENAI_TTS_VOICE=alloy            # alloy | echo | fable | onyx | nova | shimmer
# OPENAI_STT_MODEL=whisper-1
# OPENAI_TTS_MODEL=tts-1

# ── Nova chat rate limit (per user/ip) ──
# NOVA_RATE_LIMIT_MAX=10            # requests per window
# NOVA_RATE_LIMIT_WINDOW=60000      # window in ms (60_000 = 1 min)

# ── AI cost estimator (admin dashboard) ──
# USD per 1M tokens. Defaults are conservative Haiku estimates.
# AI_COST_PER_MTOK_IN=1.00
# AI_COST_PER_MTOK_OUT=5.00

# ──────────────────────────────────────────────────────────────────────────
# OmniSearch configuration
# ──────────────────────────────────────────────────────────────────────────
# Override the Anthropic model used by every OmniSearch feature (default:
# claude-haiku-4-5-20250514). Keep empty to use the default.
# OMNISEARCH_AI_MODEL=claude-haiku-4-5-20250514

# ── SERP provider (rank-tracking / position-lookup) ──
# Allowed values: serpapi | dataforseo | none (default: none → Claude estimates)
 SERP_PROVIDER=dataforseo
# SERPAPI_API_KEY=your-serpapi-key

# ── Keyword data provider (volume / CPC / difficulty) ──
# Allowed values: dataforseo | none (default: none → Claude estimates)
 KEYWORD_DATA_PROVIDER=dataforseo

# ── Backlink provider ──
# Allowed values: dataforseo | majestic | ahrefs | none (default: none)
 BACKLINK_PROVIDER=dataforseo
# MAJESTIC_API_KEY=your-majestic-key
# AHREFS_API_KEY=your-ahrefs-key

# ── DataForSEO credentials (used by SERP / keyword / backlink providers) ──
# DATAFORSEO_LOGIN=your-email@example.com
# DATAFORSEO_PASSWORD=your-dataforseo-password

# ── GEO / AEO — real AI platform keys (otherwise Claude simulates) ──
# OPENAI_API_KEY=your-openai-key
# PERPLEXITY_API_KEY=your-perplexity-key
# GOOGLE_AI_API_KEY=your-google-generative-ai-key

# ── Sentry error reporting (optional) ──
# Leave SENTRY_DSN blank to disable. If set, install @sentry/node:
#   npm install --save @sentry/node
# SENTRY_DSN=https://public@sentry.example.com/1
# SENTRY_RELEASE=localwaves@1.0.0
# SENTRY_TRACES_SAMPLE_RATE=0.1

# Google OAuth (for client Google Sign-In & analytics access)
# Create credentials at https://console.cloud.google.com/apis/credentials
# GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your-google-client-secret
# GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback
# FRONTEND_URL=http://localhost:5173

# Google Search Console — Service Account key file path
# Create a Service Account at https://console.cloud.google.com/iam-admin/serviceaccounts
# Enable Search Console API, download JSON key, and set the path here.
# Add the service account email as a user in each GSC property.
# GOOGLE_SERVICE_ACCOUNT_KEY=/path/to/service-account-key.json
