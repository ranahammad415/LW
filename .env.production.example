# Production Environment Variables
# Copy this to .env on your server and fill in the values

# Database (PostgreSQL)
# Get these from your Hostinger VPS PostgreSQL setup
DATABASE_URL="postgresql://postgres:YOUR_STRONG_PASSWORD@localhost:5432/agency_portal?schema=public"

# JWT Secrets (MUST be at least 32 characters - use random strings in production!)
JWT_ACCESS_SECRET=your-production-access-secret-at-least-32-characters-long
JWT_REFRESH_SECRET=your-production-refresh-secret-at-least-32-characters-long
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Server
PORT=3000
NODE_ENV=production

# Frontend URL (for CORS)
FRONTEND_URL=https://app.yourdomain.com

# AI Provider (choose one)
# Option A: OpenAI
AI_PROVIDER=openai
OPENAI_API_KEY=sk-your-openai-key
AI_MODEL=gpt-4o-mini

# Option B: Google Gemini
# AI_PROVIDER=gemini
# GEMINI_API_KEY=your-gemini-api-key
# AI_MODEL=gemini-2.5-flash

# Option C: Groq
# AI_PROVIDER=groq
# GROQ_API_KEY=gsk-your-groq-key
# AI_MODEL=llama-3.3-70b-versatile
